# Development environment variables
FLASK_ENV=development
FLASK_DEBUG=True
REACT_APP_API_URL=http://localhost:5000/api

# Production environment variables (uncomment and modify as needed)
# FLASK_ENV=production
# FLASK_DEBUG=False
# REACT_APP_API_URL=https://yourdomain.com/api

# Database configuration (if needed in the future)
# DATABASE_URL=sqlite:///trading.db

# Security (generate your own secret key)
SECRET_KEY=your-secret-key-here

# API Configuration
API_TIMEOUT=30000
MAX_UPLOAD_SIZE=10485760

# Data directories
DATA_DIR=DATA
INPUT_DIR=DATA/input_instruments
OUTPUT_DIR=DATA/output_instruments
PLOTS_DIR=DATA/output_plots
